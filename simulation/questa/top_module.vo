`timescale 1 ps/ 1 ps

module top_module (
	clk,
	rst_n,
	scl,
	sda,
	col,
	row,
	unlock_led);
input 	clk;
input 	rst_n;
output 	scl;
output 	sda;
input 	[3:0] col;
output 	[3:0] row;
output 	unlock_led;

